{
  "manifest_version": 3,
  "name": "Digital Tone Gap",
  "description": "AI-powered tone analysis assistant for WhatsApp conversations.",
  "version": "1.0.0",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["activeTab", "scripting", "storage", "clipboardRead", "clipboardWrite"],
  "host_permissions": [
    "https://*.whatsapp.com/*",
    "https://digital-tone-ai.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["index.html"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ]
}
